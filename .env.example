# === DATABASE ===
DB_HOST=localhost
DB_NAME=labcontrol
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# === FIREBASE ===
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=labcontrol-bd504
FIREBASE_CREDENTIALS_PATH=./firebase/service-account.json

# === SECURITY ===
JWT_SECRET=labcontrol_secure_key_$(date +%s)_change_this_in_production
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# === NETWORK ===
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# === REMOTE CREDENTIALS (Windows/Network) ===
REMOTE_USER=AdminLab17
REMOTE_PASSWORD=Insert@into17

# === LOGGING ===
LOG_ENABLED=true
LOG_RETENTION_DAYS=90
DEBUG_MODE=true

# === TIMEZONE ===
APP_TIMEZONE=America/Sao_Paulo

# === RATE LIMITING ===
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=300

# === API ===
API_RATE_LIMIT=100
API_TIMEOUT=15000
