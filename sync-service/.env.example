# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=labcontrol

# Sync interval in seconds
SYNC_INTERVAL=60

# Firebase (optional)
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=../labcontrol-backend/firebase/service-account.json

# PowerShell path (Windows)
POWERSHELL_PATH=C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe
